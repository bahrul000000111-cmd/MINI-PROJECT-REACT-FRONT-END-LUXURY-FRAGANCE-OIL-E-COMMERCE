# ─── Frägra Front-End Environment ───
# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT: URL Laravel lokal Anda
# File ini HANYA untuk development. Nilai production di-set via:
#   Vercel Dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ─── PRODUCTION (set di Vercel Dashboard, BUKAN di sini) ───
# Contoh nilai yang harus di-set di Vercel:
#   VITE_API_URL=http://123.45.67.89
#   atau
#   VITE_API_URL=https://api.domain-saya.com
